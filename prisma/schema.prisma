generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int                @id @default(autoincrement())
  username         String             @unique
  password         String
  name             String
  birth            String
  generation       Int
  message          String
  memberSeq        String?
  sodae            String?
  connect          Boolean            @default(false)
  createdAt        DateTime           @default(now())
  auth             Auth?
  posts            Post[]
  postQueue        PostQueue[]
  unconnectedPosts UnconnectedPost[]
  UnidentifiedUser UnidentifiedUser[]
  usersQueue       UsersQueue[]
}

model Auth {
  userId   Int     @id
  provider String
  password String?
  uid      String?
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([uid, provider])
}

model Post {
  id               Int               @id @default(autoincrement())
  userId           Int
  name             String
  relationship     String
  title            String
  contents         String
  password         String
  createdAt        DateTime          @default(now())
  posted           Boolean           @default(false)
  postAt           DateTime?
  isPublic         Boolean           @default(false)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  postQueues       PostQueue[]
  unconnectedPosts UnconnectedPost[]
  images           Image[]

  @@index([userId])
}

model Image {
  id     Int    @id @default(autoincrement())
  postId Int
  path    String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model UnconnectedPost {
  id     Int  @id @default(autoincrement())
  userId Int
  postId Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsersQueue {
  id        Int      @id @default(autoincrement())
  userId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UnidentifiedUser {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PostQueue {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
